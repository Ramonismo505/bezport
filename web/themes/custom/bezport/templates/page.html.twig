{#
/**
 * @file
 * Zurb Foundations's theme implementation to display a single page.
 *
 * The doctype, html, head and body tags are not in this template. Instead they
 * can be found in the html.html.twig template in this directory.
 *
 * Available variables:
 *
 * General utility variables:
 * - base_path: The base URL path of the Drupal installation. Will usually be
 *   "/" unless you have installed Drupal in a sub-directory.
 * - is_front: A flag indicating if the current page is the front page.
 * - logged_in: A flag indicating if the user is registered and signed in.
 * - is_admin: A flag indicating if the user has permission to access
 *   administration pages.
 *
 * Site identity:
 * - front_page: The URL of the front page. Use this instead of base_path when
 *   linking to the front page. This includes the language domain or prefix.
 * - site_slogan: The slogan of the site. This is empty when displaying the site
 *   slogan has been disabled in theme settings.
 *
 * Page content (in order of occurrence in the default page.html.twig):
 * - messages: Status and error messages. Should be displayed prominently.
 * - node: Fully loaded node, if there is an automatically-loaded node
 *   associated with the page and the node ID is the second argument in the
 *   page's path (e.g. node/12345 and node/12345/revisions, but not
 *   comment/reply/12345).
 *
 * Regions:
 * - page.header: 'Header'
 * - page.header_menu: Main menu in header
 * - page.breadcrumb: 'Breadcrumb'
 * - page.subheader: 'Subheader'
 * - page.help: 'Help'
 * - page.highlighted: 'Highlighted'
 * - page.content_top: 'Content top'
 * - page.content: 'Content'
 * - page.sidebar: 'Sidebar'
 * - page.content_bottom: 'Content bottom'
 * - page.footer: 'Footer'
 * - page.bottom_support: 'Bottom support'
 *
 * Note: 'page_top' and 'page_bottom' are rendered in html.html.twig.
 *
 * @see template_preprocess_page()
 * @see html.html.twig
 */
#}

<div id="page-container">
  <div id="page-wrapper">
    <div id="page" class="{{ page_suggestion }}-template">
      {% if page.header or page.header_menu %}
        <div class="header-container">        
          <header id="header" class="site-header" role="banner" aria-label="{{ 'Site header'|t }}">
            <div class="header-content-container">
              {% if page.header %}
                <div class="header-content-wrapper grid-container">
                  <div class="header-content">
                    {{ page.header }}
                  </div>
                </div>
              {% endif %}
            </div>
            {% if page.header_menu %}
              {{ page.header_menu }}
            {% endif %}  
          </header>        
        </div>
      {% endif %}
      
      {% if page.breadcrumb %}
        <div class="breadcrumb-container">
          <div class="breadcrumb-wrapper grid-container">          
            {{ page.breadcrumb }}          
          </div>
        </div>
      {% endif %}

      {% if page.subheader %}
        <div class="subheader-container">
          <div class="subheader-wrapper">          
            {{ page.subheader }}          
          </div>
        </div>
      {% endif %}

      <div class="main-container-wrapper main-container-wrapper--{{ page_suggestion }}">
        <div id="main-container" class="main-container main-container--{{ page_suggestion }} grid-container">

          {% if page.help %}
            <div{{ help_attributes }}>
              {{ page.help }}
            </div>
          {% endif %}

          {% if page.highlighted %}
            <div class="highlighted-container">
              {{ page.highlighted }}
            </div>
          {% endif %}

          <main id="main" class="main-content-wrapper" role="main">
            <a id="main-content" tabindex="-1"></a>{# link is in html.html.twig #}

            {% if page.content_top %}
              <div id="content-top-container">                
                {{ page.content_top }}
              </div>
            {% endif %}

            {% if page_suggestion == 'login' %} 
              <div class="page-login-container"> 
                <div class="page-login-wrapper">                
                  {{ page.content }}
                </div>
              </div>
            {% elseif page_suggestion == 'access_denied' %}
              <div class="page-ad-container"> 
                <div class="page-ad-wrapper">                
                  {{ page.content }}
                </div>
              </div>
            {% else %}
              <div{{ content_attributes }}>
                {% if page.content %}
                  {{ page.content }}
                {% endif %}
              </div>
            {% endif %}

          </main>

          {% if page_suggestion == 'common' %}
            <aside id="sidebar-container" class="sidebar-container">
              <div class="sidebar-wrapper">
                {% if page.sidebar %}
                  {{ page.sidebar }}
                {% endif %}
              </div>
            </aside>
          {% endif %}

        </div>{# #main-container #}
      </div>{# #main-container-wrapper #}

      {% if page.content_bottom %}
        <div id="content-bottom-container">
          <div class="content-bottom-wrapper grid-container">        
            {{ page.content_bottom }}        
          </div>
        </div>
      {% endif %}


    </div>{# #page #}

    <footer id="footer" class="footer">
      {% if page.footer %}
        <div class="footer-container">
          <div class="footer-wrapper grid-container clearfix">
            {{ page.footer }}
          </div>
        </div>
      {% endif %}    
    </footer>

    {% if page.bottom_support %}
      {{ page.bottom_support }}
    {% endif %}

  </div>{# #page-wrapper #}
  <div id="bottom-spacer"></div>
</div>{# #page-container #}
